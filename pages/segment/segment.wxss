.segment-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.segment-orb {
  width: 220rpx;
  height: 220rpx;
}

.orb-top {
  top: 40rpx;
  right: -80rpx;
}

.orb-side {
  top: 340rpx;
  left: -60rpx;
}

.segment-nav {
  display: flex;
}

.segment-hero {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.segment-brand-slot {
  display: flex;
}

.segment-title {
  font-size: 58rpx;
  line-height: 1.08;
  color: var(--text-primary);
  font-weight: 800;
}

.segment-subtitle {
  font-size: 28rpx;
  line-height: 1.68;
  color: var(--text-secondary);
}

.segment-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.student-panel,
.segment-ai,
.history-panel {
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.panel-head {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.panel-copy {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.panel-title {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 700;
}

.panel-subtitle {
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.panel-actions {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.compact-cta {
  min-height: 72rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
}

.student-list,
.history-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.student-card,
.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: var(--radius-lg);
  background: rgba(255, 255, 255, 0.92);
  border: 2rpx solid var(--border-soft);
}

.student-card.is-selected {
  border-color: var(--border-strong);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(255, 240, 218, 0.9));
}

.student-main,
.history-main,
.history-side {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.student-main,
.history-main {
  flex: 1;
  min-width: 0;
}

.student-name,
.history-title {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 700;
}

.student-meta,
.history-meta,
.history-confidence {
  font-size: 22rpx;
  line-height: 1.6;
  color: var(--text-secondary);
}

.student-check {
  width: 46rpx;
  height: 46rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-soft);
  color: var(--brand-primary-deep);
  font-size: 26rpx;
  font-weight: 700;
}

.student-form {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.form-title {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 700;
}

.form-field {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.field-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 600;
}

.field-input,
.picker-display {
  min-height: 88rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 2rpx solid var(--border-soft);
  color: var(--text-primary);
  font-size: 28rpx;
  display: flex;
  align-items: center;
}

.form-actions {
  display: flex;
  gap: 14rpx;
}

.compact-save {
  flex: 1;
  min-height: 84rpx;
  font-size: 26rpx;
}

.segment-ai {
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.ai-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.history-side {
  align-items: flex-end;
  text-align: right;
}

.history-score {
  font-size: 34rpx;
  color: var(--brand-primary-deep);
  font-weight: 800;
}

.empty-block {
  padding: 18rpx 0 8rpx;
}

.empty-text {
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--text-secondary);
}

.segment-footer {
  margin-top: auto;
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.footer-copy {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.footer-tip,
.footer-preview {
  font-size: 24rpx;
  line-height: 1.65;
}

.footer-tip {
  color: var(--text-secondary);
}

.footer-preview {
  color: var(--brand-primary-deep);
  font-weight: 600;
}
