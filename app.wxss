page {
  min-height: 100%;
  background: #fff8ef;
  color: #20323a;
  font-family: "Avenir Next", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
  box-sizing: border-box;
}

view,
text,
button,
navigator {
  box-sizing: border-box;
}

.page-shell {
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  background:
    radial-gradient(circle at top left, rgba(255, 201, 143, 0.34), transparent 38%),
    radial-gradient(circle at top right, rgba(124, 204, 187, 0.18), transparent 32%),
    linear-gradient(180deg, var(--bg-page) 0%, var(--bg-page-secondary) 100%);
  color: var(--text-primary);
  padding: 48rpx 28rpx calc(52rpx + env(safe-area-inset-bottom));
}

.page-shell.theme-child {
  --brand-primary: #ff8a3d;
  --brand-primary-deep: #eb6e20;
  --brand-secondary: #ffe2a4;
  --brand-accent: #62c99c;
  --trust-brand-bg: rgba(234, 248, 243, 0.92);
  --trust-brand-border: rgba(84, 164, 140, 0.2);
  --trust-brand-text: #2f7365;
  --trust-brand-accent: #6bc5aa;
  --trust-brand-shadow: 0 12rpx 30rpx rgba(78, 153, 132, 0.12);
  --trust-brand-muted: rgba(47, 115, 101, 0.54);
  --success: #43b86e;
  --warning: #ffba53;
  --text-primary: #24333b;
  --text-secondary: #60727b;
  --text-tertiary: #81929a;
  --bg-page: #fff8ef;
  --bg-page-secondary: #fffef9;
  --bg-surface: #ffffff;
  --bg-soft: #fff0da;
  --bg-contrast: #f7fbf7;
  --border-soft: rgba(255, 138, 61, 0.16);
  --border-strong: rgba(255, 138, 61, 0.3);
  --shadow-card: 0 28rpx 72rpx rgba(235, 110, 32, 0.12);
  --shadow-soft: 0 14rpx 32rpx rgba(67, 184, 110, 0.12);
  --radius-xs: 16rpx;
  --radius-sm: 22rpx;
  --radius-md: 28rpx;
  --radius-lg: 34rpx;
  --radius-xl: 42rpx;
  --space-2xs: 8rpx;
  --space-xs: 12rpx;
  --space-sm: 18rpx;
  --space-md: 24rpx;
  --space-lg: 32rpx;
  --space-xl: 40rpx;
  --font-caption: 22rpx;
  --font-body: 28rpx;
  --font-subtitle: 32rpx;
  --font-title: 48rpx;
  --font-display: 72rpx;
  --hero-radius: 44rpx;
  --option-height: 120rpx;
}

.page-shell.theme-student {
  --brand-primary: #1e8e84;
  --brand-primary-deep: #156a68;
  --brand-secondary: #cdece8;
  --brand-accent: #3f6dd8;
  --trust-brand-bg: rgba(232, 245, 242, 0.94);
  --trust-brand-border: rgba(30, 142, 132, 0.18);
  --trust-brand-text: #1d6f68;
  --trust-brand-accent: #4fb59f;
  --trust-brand-shadow: 0 12rpx 30rpx rgba(17, 74, 81, 0.1);
  --trust-brand-muted: rgba(29, 111, 104, 0.46);
  --success: #2f9e6f;
  --warning: #ef9e41;
  --text-primary: #19313b;
  --text-secondary: #5a6f79;
  --text-tertiary: #7d9098;
  --bg-page: #f3fbf8;
  --bg-page-secondary: #fbfdfc;
  --bg-surface: #ffffff;
  --bg-soft: #e8f5f2;
  --bg-contrast: #eef5fb;
  --border-soft: rgba(30, 142, 132, 0.14);
  --border-strong: rgba(30, 142, 132, 0.26);
  --shadow-card: 0 24rpx 60rpx rgba(18, 58, 66, 0.1);
  --shadow-soft: 0 12rpx 28rpx rgba(63, 109, 216, 0.1);
  --radius-xs: 14rpx;
  --radius-sm: 18rpx;
  --radius-md: 24rpx;
  --radius-lg: 30rpx;
  --radius-xl: 36rpx;
  --space-2xs: 8rpx;
  --space-xs: 12rpx;
  --space-sm: 16rpx;
  --space-md: 22rpx;
  --space-lg: 28rpx;
  --space-xl: 36rpx;
  --font-caption: 22rpx;
  --font-body: 28rpx;
  --font-subtitle: 32rpx;
  --font-title: 42rpx;
  --font-display: 64rpx;
  --hero-radius: 36rpx;
  --option-height: 100rpx;
}

.surface-card {
  background: var(--bg-surface);
  border: 2rpx solid var(--border-soft);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-card);
}

.soft-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 255, 255, 0.86));
  border: 2rpx solid rgba(255, 255, 255, 0.6);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-soft);
}

.soft-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: var(--bg-soft);
  color: var(--brand-primary-deep);
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.back-pill {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  min-width: 120rpx;
  height: 64rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.74);
  border: 2rpx solid rgba(255, 255, 255, 0.82);
  color: var(--text-primary);
}

.back-pill:active {
  transform: scale(0.98);
}

.back-icon {
  font-size: 38rpx;
  line-height: 1;
}

.back-text {
  font-size: 24rpx;
  font-weight: 600;
}

.title-xl {
  font-size: var(--font-title);
  line-height: 1.15;
  font-weight: 700;
}

.title-lg {
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 700;
}

.text-body {
  font-size: var(--font-body);
  line-height: 1.6;
}

.text-secondary {
  color: var(--text-secondary);
}

.text-tertiary {
  color: var(--text-tertiary);
}

.primary-cta,
.secondary-cta,
.ghost-cta {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 104rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  transition: transform 180ms ease, opacity 180ms ease, box-shadow 180ms ease;
}

.primary-cta {
  color: #ffffff;
  background: linear-gradient(135deg, var(--brand-primary) 0%, var(--brand-primary-deep) 100%);
  box-shadow: 0 18rpx 40rpx rgba(235, 110, 32, 0.24);
}

.theme-student .primary-cta {
  box-shadow: 0 18rpx 40rpx rgba(21, 106, 104, 0.2);
}

.secondary-cta {
  color: var(--brand-primary-deep);
  background: rgba(255, 255, 255, 0.88);
  border: 2rpx solid var(--border-strong);
}

.ghost-cta {
  color: var(--text-secondary);
  background: rgba(255, 255, 255, 0.64);
  border: 2rpx solid rgba(255, 255, 255, 0.68);
}

.primary-cta.is-disabled,
.secondary-cta.is-disabled,
.ghost-cta.is-disabled {
  opacity: 0.46;
  box-shadow: none;
}

.primary-cta:active,
.secondary-cta:active,
.ghost-cta:active {
  transform: translateY(2rpx) scale(0.99);
}

.floating-orb {
  position: absolute;
  border-radius: 999rpx;
  filter: blur(1rpx);
  opacity: 0.72;
  pointer-events: none;
}

.floating-orb.warm {
  background: radial-gradient(circle, rgba(255, 193, 113, 0.8), rgba(255, 193, 113, 0.1));
}

.floating-orb.mint {
  background: radial-gradient(circle, rgba(115, 209, 180, 0.68), rgba(115, 209, 180, 0.1));
}

.floating-orb.blue {
  background: radial-gradient(circle, rgba(98, 137, 234, 0.42), rgba(98, 137, 234, 0.08));
}

.fade-up {
  animation: fadeUp 420ms ease both;
}

.pop-in {
  animation: popIn 260ms ease both;
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(18rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes popIn {
  from {
    opacity: 0;
    transform: scale(0.96);
  }

  to {
    opacity: 1;
    transform: scale(1);
  }
}
